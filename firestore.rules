rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Único negócio, com mais de um admin (Ivan e Gabriel) logando com uids
    // diferentes. Antes a regra exigia request.auth.uid == businessId, o que
    // só funcionava para quem criou o negócio (uid == businessId por design).
    // Agora qualquer uid desta lista é tratado como admin do negócio,
    // independente do path businessId. Se um novo admin entrar, adicione o
    // uid aqui também (e em ADMIN_EMAILS / useAuth.ts no client).
    function isBizAdmin() {
      return request.auth != null && (
        request.auth.uid == "1wLgfQXpYAOZMmXDZzZicurIFFT2"
        || request.auth.uid == "q9D5H72UFrZZDMcoS2ENXvAvrzL2"
      );
    }

    // ── Collection group: sessions ──────────────────────────────────────
    // Leitura pública: a landing mostra os horários disponíveis sem login e
    // o aluno consulta sem conhecer o businessId (query collectionGroup).
    // Escrita continua governada pela regra aninhada em businesses/{id}/sessions.
    match /{path=**}/sessions/{sessionId} {
      allow read: if true;
    }

    // ── Collection group: reservations ──────────────────────────────────
    // O aluno consulta as PRÓPRIAS reservas sem conhecer o businessId.
    match /{path=**}/reservations/{reservationId} {
      allow read: if request.auth != null
                  && resource.data.customerId == request.auth.uid;
    }

    // ── Business ────────────────────────────────────────────────────────
    match /businesses/{businessId} {
      allow read:   if isBizAdmin();
      allow create: if isBizAdmin();
      allow update: if isBizAdmin();
      allow delete: if false; // nunca deletar um negócio via cliente

      // ── Customers ──────────────────────────────────────────────────
      match /customers/{customerId} {
        // Admin lê e escreve todos; aluno lê só o próprio perfil
        allow read:  if request.auth != null
                     && (isBizAdmin() || request.auth.uid == customerId);
        // Admin cria/apaga qualquer um; aluno pode criar o PRÓPRIO cadastro
        // (registro) desde que não comece com créditos já carregados.
        allow create: if request.auth != null && (
          isBizAdmin()
          || (
            request.auth.uid == customerId
            && (!('creditBalance' in request.resource.data) || request.resource.data.creditBalance == 0)
          )
        );
        allow delete: if isBizAdmin();
        // Admin atualiza livremente; aluno pode:
        //   1. Gastar/receber crédito (reserva/cancelamento)
        //   2. Atualizar o próprio perfil (phone, birthDate, name)
        //   3. Registrar conquistas/xp/level
        allow update: if request.auth != null && (
          isBizAdmin()
          || (
            request.auth.uid == customerId
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['creditBalance', 'updatedAt'])
            && (
              (request.resource.data.creditBalance == resource.data.creditBalance - 1
               && request.resource.data.creditBalance >= 0)
              || request.resource.data.creditBalance == resource.data.creditBalance + 1
            )
          )
          || (
            request.auth.uid == customerId
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['phone', 'birthDate', 'name', 'updatedAt'])
          )
          || (
            request.auth.uid == customerId
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['achievements', 'xp', 'level', 'updatedAt'])
          )
          || (
            request.auth.uid == customerId
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['hasSeenOnboarding', 'updatedAt'])
          )
        );
      }

      // ── Sessions ───────────────────────────────────────────────────
      match /sessions/{sessionId} {
        // Qualquer autenticado pode ver os horários disponíveis
        allow read:   if request.auth != null;
        // Só o admin cria/remove aulas
        allow create, delete: if isBizAdmin();
        // Admin atualiza livremente; aluno pode incrementar 1 (reserva) ou
        // decrementar 1 (cancelamento), nunca ultrapassar o máximo nem ficar negativo.
        allow update: if request.auth != null && (
          isBizAdmin()
          || (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['currentCapacity', 'updatedAt'])
            && (
              (request.resource.data.currentCapacity == resource.data.currentCapacity + 1
               && request.resource.data.currentCapacity <= resource.data.maxCapacity)
              || (request.resource.data.currentCapacity == resource.data.currentCapacity - 1
                  && request.resource.data.currentCapacity >= 0)
            )
          )
        );
      }

      // ── Reservations (horários reservados por aluno) ───────────────
      match /reservations/{reservationId} {
        // Admin vê todas; aluno vê as próprias
        allow read:  if request.auth != null
                     && (isBizAdmin() || resource.data.customerId == request.auth.uid);
        // Aluno cria a própria reserva; admin gerencia (confirmar, cancelar)
        allow create: if request.auth != null
                      && (isBizAdmin() || request.resource.data.customerId == request.auth.uid);
        // Aluno pode: 1. cancelar a própria reserva (status → cancelled) ou
        // 2. reportar pagamento pix (status reserved → confirmed)
        allow update: if request.auth != null && (
          isBizAdmin()
          || (
            resource.data.customerId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
            && request.resource.data.status == 'cancelled'
            && resource.data.status != 'cancelled'
            && resource.data.status != 'completed'
          )
          || (
            resource.data.customerId == request.auth.uid
            && resource.data.payment == 'pix'
            && resource.data.status == 'reserved'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
            && request.resource.data.status == 'confirmed'
          )
        );
        allow delete: if isBizAdmin();
      }

      // ── Progress Logs ──────────────────────────────────────────────
      match /progress-logs/{logId} {
        allow read:  if request.auth != null
                     && (isBizAdmin() || resource.data.customerId == request.auth.uid);
        allow write: if isBizAdmin();
      }

      // ── Payments ───────────────────────────────────────────────────
      match /payments/{paymentId} {
        allow read:  if request.auth != null
                     && (isBizAdmin() || resource.data.customerId == request.auth.uid);
        allow create: if request.auth != null;
        allow update: if isBizAdmin();
        allow delete: if false;
      }

      // ── Packages ───────────────────────────────────────────────────
      match /packages/{packageId} {
        // Qualquer autenticado vê os pacotes disponíveis
        allow read:  if request.auth != null;
        allow write: if isBizAdmin();
      }
    }
  }
}
